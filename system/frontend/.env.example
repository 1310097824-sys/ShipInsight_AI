VITE_MAP_PROVIDER=amap
# amap: hybrid mode. Uses global imagery by default and overlays Gaode vector tiles
# when zooming into mainland China, avoiding overseas "no satellite image" placeholders.
# esri/global: global imagery only, best for overseas observation points.
# amap-vector: Gaode vector tiles only, best for mainland China street context.
# Optional: if you prefer official Tianditu tiles, switch provider to tianditu
# and fill your own key below.
# VITE_MAP_PROVIDER=tianditu
# VITE_TIANDITU_KEY=your-tianditu-key
